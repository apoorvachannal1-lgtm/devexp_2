<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>My Simple Website</title>

    <style>
        /* Reset */
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
            font-family: Arial, sans-serif;
        }

        /* Navbar */
        nav {
            background: #333;
            color: white;
            padding: 15px;
            display: flex;
            justify-content: space-between;
        }

        nav h1 {
            font-size: 22px;
        }

        nav ul {
            list-style: none;
            display: flex;
            gap: 20px;
        }

        nav ul li {
            cursor: pointer;
        }

        nav ul li:hover {
            color: #00adb5;
        }

        /* Hero Section */
        .hero {
            height: 80vh;
            background: linear-gradient(to right, #00adb5, #393e46);
            color: white;
            display: flex;
            flex-direction: column;
            justify-content: center;
            align-items: center;
            text-align: center;
        }

        .hero h2 {
            font-size: 40px;
            margin-bottom: 10px;
        }

        .hero p {
            font-size: 18px;
            margin-bottom: 20px;
        }

        .hero button {
            padding: 10px 20px;
            border: none;
            background: white;
            color: #333;
            cursor: pointer;
            border-radius: 5px;
        }

        .hero button:hover {
            background: #eeeeee;
        }

        /* About Section */
        .about {
            padding: 50px;
            text-align: center;
        }

        .about h2 {
            margin-bottom: 15px;
        }

        /* Footer */
        footer {
            background: #333;
            color: white;
            text-align: center;
            padding: 15px;
        }
    </style>
</head>

<body>

<!-- Navbar -->
<nav>
    <h1>MySite</h1>
    <ul>
        <li>Home</li>
        <li>About</li>
        <li>Contact</li>
    </ul>
</nav>

<!-- Hero Section -->
<section class="hero">
    <h2>Welcome to My Website</h2>
    <p>This is a simple HTML + CSS project</p>
    <button>Get Started</button>
</section>

<!-- About Section -->
<section class="about">
    <h2>About Us</h2>
    <p>This website is created using basic HTML and CSS. It is clean, responsive, and beginner-friendly.</p>
</section>

<!-- Footer -->
<footer>
    <p>© 2026 My Website | All Rights Reserved</p>
</footer>

</body>
</html>
